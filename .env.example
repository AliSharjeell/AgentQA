# AgentQA CLI Environment Variables

# API Provider
QA_API_PROVIDER=anthropic
QA_API_KEY=sk-ant-api03-xxx

# Optional custom base URL (if using a proxy or alternative endpoint)
QA_API_URL=https://api.anthropic.com

# Model
QA_API_MODEL=claude-3-5-sonnet-20241022

# Browser-harness timeout in milliseconds (default: 120000)
QA_BROWSER_TIMEOUT_MS=300000

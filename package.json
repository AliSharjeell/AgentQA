{
  "name": "qa-automation-ai",
  "version": "0.1.0",
  "description": "AI-powered QA automation desktop app with live browser preview, task management, and AI-driven test execution using browser-use",
  "main": "out/main/index.js",
  "bin": {
    "qa-cli": "./out/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "build:cli": "node scripts/build-cli.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:cli": "tsc --noEmit -p tsconfig.cli.json",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@vitejs/plugin-react": "^4.3.4",
    "anthropic": "^0.0.0",
    "browser-use": "^0.6.1",
    "chromium-bidi": "^0.5.24",
    "electron": "^34.0.2",
    "electron-vite": "^3.0.0",
    "lucide-react": "^0.468.0",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
